<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bucket_header"
    style="@style/BucketHeader">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/header_contents"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/bucket_header">
        <ImageView
            android:gravity="center"
            android:id="@+id/header_icon"
            android:layout_width="@dimen/bucket_header_icon_width"
            android:layout_height="@dimen/bucket_header_icon_width"/>
        <TextView
            android:gravity="center_vertical"
            android:id="@+id/section_header"
            android:layout_height="match_parent"
            style="@style/BucketHeaderText"/>
        <ImageView
            android:gravity="center_vertical"
            android:id="@+id/big_section_more_arrow"
            android:paddingLeft="15dp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/bucket_header_info"
            android:gravity="center_vertical"
            android:id="@+id/section_results"
            android:layout_height="match_parent"
            style="@style/BucketHeaderText"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="normal"
            android:textColor="@color/bucket_header_info"
            android:gravity="center_vertical"
            android:id="@+id/header_more_results_link"
            android:visibility="invisible"
            android:layout_height="match_parent"
            android:text="@string/search_more_results"
            style="@style/BucketHeaderText"/>
    </LinearLayout>
</FrameLayout>
