<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:id="@+id/promo_flyover"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ImageView
        android:gravity="center_vertical"
        android:id="@+id/icon"
        android:paddingLeft="5dp"
        android:paddingTop="@dimen/promo_flyover_top_bottom_padding"
        android:paddingRight="5dp"
        android:paddingBottom="@dimen/promo_flyover_top_bottom_padding"
        android:layout_width="@dimen/promo_flyover_contents_width"
        android:layout_height="match_parent"
        android:scaleType="centerInside"
        android:adjustViewBounds="false"
        android:layout_weight="1"/>
    <Button
        android:id="@+id/buy_link"
        android:layout_width="@dimen/promo_flyover_contents_width"
        android:layout_marginBottom="@dimen/promo_flyover_buy_button_bottom_margin"
        style="@style/DetailsPage_BuyButton"/>
</LinearLayout>
