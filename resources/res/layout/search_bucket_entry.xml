<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="@dimen/bucket_entry_search_height"
    style="@style/GridCell">
    <include layout="@layout/bucket_entry_contents"/>
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/li_thumbnail"
        android:layout_alignParentLeft="true"
        android:layout_alignParentBottom="true">
        <RatingBar
            android:id="@+id/li_rating"
            android:paddingTop="4dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:stepSize="0.5"
            android:isIndicator="true"
            style="@style/FinskyRatingBarSmall"/>
        <TextView
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:id="@+id/li_rating_count"
            android:paddingLeft="10dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_alignParentBottom="true"/>
    </LinearLayout>
</RelativeLayout>
